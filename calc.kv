BoxLayout:
    orientation: 'vertical'

    Label:
        text: 'Calc'
        font_size: 40
        size_hint_y: 0.2

    GridLayout:
        cols: 4
        size_hint_y: 0.8

        Button:
            text: '1'
        Button:
            text: '2'
        Button:
            text: '3'
        Button:
            text: '+'
        Button:
            text: '4'
            text: '4'
        Button:
            text: '5'
        Button:
            text: '6'
        Button:
            text: '-'
